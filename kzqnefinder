-- ================== CORE FUNCTIONS (same as before, improved) ==================
local function sendWebhook(title, desc)
    if Config.Webhook == "" then return end
    -- (same webhook code as previous script - works with syn/request/http_request)
    pcall(function()
        local req = (syn and syn.request) or request or http_request
        req({Url = Config.Webhook, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = HttpService:JSONEncode({embeds = {{title = title, description = desc, color = 0x00FF00}}})})
    end)
end

local function getBrainrotValue(br) -- flexible for patches
    for _, v in {"Value", "Worth", "Price"} do
        if br:FindFirstChild(v) and br[v]:IsA("NumberValue") then return br[v].Value end
        if br:GetAttribute(v) then return br:GetAttribute(v) end
    end
    return 0
end

local function hasHighValue(player)
    if player == LP then return false end
    local paths = {player:FindFirstChild("Brainrots"), player.Character and player.Character:FindFirstChild("Brainrots"), player.Backpack and player.Backpack:FindFirstChild("Brainrots"), player:FindFirstChild("Data") and player.Data:FindFirstChild("Brainrots")}
    for _, folder in paths do
        if folder then
            for _, br in folder:GetChildren() do
                local val = getBrainrotValue(br)
                if val >= Config.MinValue then
                    return true, br.Name, val, player
                end
            end
        end
    end
    return false
end

local function createESP(player, name, value)
    if not Config.EnableESP or not player.Character then return end
    local hl = Instance.new("Highlight")
    hl.FillColor = Color3.fromRGB(0, 255, 0)
    hl.OutlineColor = Color3.fromRGB(0, 255, 0)
    hl.Parent = player.Character
    -- Billboard text same as before
end

local function attemptSteal(player)
    if not Config.AutoSteal then return end
    local remote = ReplicatedStorage:FindFirstChild("StealEvent") or ReplicatedStorage.Remotes:FindFirstChild("Steal") or ReplicatedStorage:FindFirstChild("BrainrotSteal")
    if remote then pcall(function() remote:FireServer(player) end) end
end

local function hopServer() TeleportService:Teleport(placeId) end

-- ================== MAIN FINDER LOOP ==================
local function finderLoop()
    while Config.Running do
        StatusLabel.Text = "Status: Scanning server for >10M..."
        local found = false
        for _, plr in Players:GetPlayers() do
            local has, name, val, owner = hasHighValue(plr)
            if has then
                found = true
                local msg = owner.Name .. " has " .. name .. " (" .. math.floor(val/1000000) .. "M)"
                StatusLabel.Text = "Status: 10M+ FOUND! " .. msg
                sendWebhook("10M+ BRAINROT FOUND!", msg)
                createESP(owner, name, val)
                attemptSteal(owner)
                if Config.StayIfFound then
                    StatusLabel.Text = "Status: STAYING — Jackpot server!"
                    return -- stay
                end
            end
        end
        if not found then
            StatusLabel.Text = "Status: No 10M+ — hopping in " .. Config.HopDelay .. "s"
            wait(Config.ScanDelay)
            hopServer()
        end
        wait(Config.HopDelay)
    end
end

