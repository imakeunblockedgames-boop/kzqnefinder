-- ================== Flexible Detection (survives patches like real finders) ==================
local function getValue(br)
    for _, k in {"Value", "Worth", "Price"} do
        if br:FindFirstChild(k) and br[k]:IsA("NumberValue") then return br[k].Value end
        if br:GetAttribute(k) then return br:GetAttribute(k) end
    end
    return 0
end

local function scanServer()
    for _, plr in Players:GetPlayers() do
        if plr == LP then continue end
        local paths = {plr:FindFirstChild("Brainrots"), plr.Character and plr.Character:FindFirstChild("Brainrots"), plr.Backpack and plr.Backpack:FindFirstChild("Brainrots"), plr:FindFirstChild("Data") and plr.Data:FindFirstChild("Brainrots")}
        for _, folder in paths do
            if folder then
                for _, br in folder:GetChildren() do
                    local val = getValue(br)
                    if val >= Config.MinValue then
                        addToList(plr.Name, br.Name, val)
                        -- ESP + webhook + steal here (full script has them)
                    end
                end
            end
        end
    end
end

-- ================== Spam Hop + Main Loop (exactly like Lennranda/Mari) ==================
local function hopServer() TeleportService:Teleport(placeId) end

local function mainLoop()
    while Config.Running do
        scanServer()
        if Config.SpamHop then
            wait(Config.SpamHopSpeed)
            hopServer()
        else
            wait(Config.HopDelay)
            if not Config.StayIfFound then hopServer() end
        end
    end
end

