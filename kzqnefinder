local function addToggle(parent, y, text, default, callback)
    local tog = Instance.new("TextButton")
    tog.Size = UDim2.new(0.9, 0, 0, 40)
    tog.Position = UDim2.new(0.05, 0, 0, y)
    tog.BackgroundColor3 = default and Color3.fromRGB(0, 170, 0) or Color3.fromRGB(40, 40, 40)
    tog.Text = text .. ": " .. (default and "ON" or "OFF")
    tog.TextColor3 = Color3.new(1,1,1)
    tog.Parent = parent
    Instance.new("UICorner", tog).CornerRadius = UDim.new(0, 8)
    tog.MouseButton1Click:Connect(function()
        default = not default
        tog.BackgroundColor3 = default and Color3.fromRGB(0, 170, 0) or Color3.fromRGB(40, 40, 40)
        tog.Text = text .. ": " .. (default and "ON" or "OFF")
        callback(default)
    end)
    return tog
end

