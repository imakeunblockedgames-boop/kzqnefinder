local function addToLog(playerName, brainrotName, value)
    table.insert(foundList, {time = os.date("%H:%M"), player = playerName, name = brainrotName, val = math.floor(value/1000000)})
    
    local entry = Instance.new("TextLabel")
    entry.Size = UDim2.new(1,0,0,30)
    entry.BackgroundTransparency = 0.7
    entry.BackgroundColor3 = Color3.fromRGB(0,50,0)
    entry.Text = string.format("%s | %s (%sM) | %s", playerName, brainrotName, math.floor(value/1000000), os.date("%H:%M"))
    entry.TextColor3 = Color3.fromRGB(0,255,100)
    entry.Font = Enum.Font.Gotham
    entry.TextScaled = true
    entry.Parent = LogFrame
    LogFrame.CanvasSize = UDim2.new(0,0,0, #foundList * 35)
end

