-- Rising Platform
local function togglePlatform(on)
    if on then
        platformPart = Instance.new("Part")
        platformPart.Size = Vector3.new(6,0.5,6)
        platformPart.Transparency = 0.4
        platformPart.Color = Color3.fromRGB(0,255,100)
        platformPart.Anchored = true
        platformPart.CanCollide = true
        platformPart.Parent = workspace
        connections.platform = RunService.Heartbeat:Connect(function()
            if LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
                platformPart.CFrame = LP.Character.HumanoidRootPart.CFrame * CFrame.new(0, -3 - Config.PlatformHeight, 0)
            end
        end)
    else
        if platformPart then platformPart:Destroy() end
        if connections.platform then connections.platform:Disconnect() end
    end
end

-- TP to Nearest Base
local function tpToBase()
    local closest, dist = nil, math.huge
    for _, plr in Players:GetPlayers() do
        if plr ~= LP and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local d = (plr.Character.HumanoidRootPart.Position - LP.Character.HumanoidRootPart.Position).Magnitude
            if d < dist then closest, dist = plr, d end
        end
    end
    if closest and LP.Character then
        LP.Character.HumanoidRootPart.CFrame = closest.Character.HumanoidRootPart.CFrame + Vector3.new(0,5,0)
    end
end

